    "@prisma/config"                : "catalog:db"
  },
  "devDependencies"   : {
    "@types/node"                   : "catalog:type",
    "@types/pg"                     : "^8.18.0",
    "prisma"                        : "catalog:db",
    "typescript"                    : "catalog:base"
  },

  "exports"           : {
    "."             : "./src/index.ts",
    "./browser"     : "./src/client/index.ts",
    "./client"      : "./src/client/client.ts",
    "./edge"        : "./src/client/edge.ts"
  },

  "publishConfig"     : {
    "access"    : "public"
  },
  "publisher"         : {
    "type"      : "github",
