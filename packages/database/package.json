{
  "private"           : true,
  "name"              : "@obvia/database",
  "description"       : "Reusable database presets for consistent schema design, type-safe queries, and scalable database workflows across projects.",
  "keywords"          : ["obvia", "prisma", "postgresql", "type-safe", "orm", "schema", "preset", "database-tools", "database", "workflows"],
  "license"           : "MIT",
