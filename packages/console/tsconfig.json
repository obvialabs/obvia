{
  "extends"         : "@pooxlabs/presets/react-config",
  "compilerOptions" : {
    "baseUrl" : ".",
    "module"  : "ESNext",
    "moduleResolution": "bundler",
    "paths"   : {
      "@poox/*"             : ["src/*"],
      "@pooxlabs/console"   : ["src"],
    }
  },
  "include"         : ["."],
  "exclude"         : ["dist", "build", "node_modules"]
}
