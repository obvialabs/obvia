{
  "name"              : "@pooxlabs/presets",
  "description"       : "A centralized configuration layer for the Poox ecosystem—defining shared typescript, eslint, and tooling presets to enforce consistency, reduce setup overhead, and accelerate contributor onboarding. Designed for modularity, semantic clarity, and teardown-safe development across diverse project environments.",
  "keywords"          : ["typescript", "eslint", "eslint-config", "eslint-preset", "code-style", "linting", "type-safe", "shared-config", "modular", "teardown-safe", "semantic", "onboarding-friendly", "developer-experience", "poox"],
  "license"           : "MIT",
  "homepage"          : "https://poox.io/",
  "version"           : "0.0.1",

  "author"            : {
    "name"      : "Selçuk Çukur",
    "email"     : "selcukcukur@outlook.com.tr",
    "url"       : "https://selcukcukur.com.tr"
  },

  "bugs"              : {
    "email"   : "security@poox.io",
    "url"     : "https://github.com/pooxlabs/poox/issues"
  },

  "scripts"           : {
    "clean" : "rimraf node_modules dist .turbo"
  },

  "main"              : "./dist/index.mjs",
  "module"            : "./dist/index.mjs",
  "types"             : "./dist/index.d.ts",

  "devDependencies"   : {
    "@eslint/js"                : "^10.0.1",
    "@next/eslint-plugin-next"  : "^16.1.6",
    "eslint"                    : "^10.0.0",
    "eslint-config-prettier"    : "^10.1.8",
    "eslint-plugin-only-warn"   : "^1.1.0",
    "eslint-plugin-react"       : "^7.37.5",
    "eslint-plugin-react-hooks" : "^7.0.1",
    "eslint-plugin-turbo"       : "^2.8.3",
    "globals"                   : "^17.3.0",
    "typescript"                : "^5.9.3",
    "typescript-eslint"         : "^8.54.0"
  },

  "exports"           : {
    "./base-eslint"     : "./src/base.js",
    "./next-eslint"     : "./src/next.js",
    "./react-eslint"    : "./src/react.js",
    "./base-config"     : "./src/base.json",
    "./next-config"     : "./src/next.json",
    "./react-config"    : "./src/react.json"
  },

  "publishConfig"     : {
    "access"  : "public"
  },
  "publisher"         : {
    "type" : "github",
    "user" : "pooxlabs",
    "repo" : "poox"
  },
  "repository"        : {
    "type"  : "git",
    "url"   : "git+https://github.com/pooxlabs/poox.git"
  }
}
