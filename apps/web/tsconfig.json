{
  "extends"         : "@obvia/presets/next-config",
  "compilerOptions" : {
    "baseUrl" : ".",
    "paths"   : {
      "@/*"                     : ["*"],
      "@interface/*"            : ["./interface/*"],
      "@library/*"              : ["./library/*"]
    }
  },
  "include"         : ["**/*.ts", "**/*.tsx", "**/*.d.ts", "next-env.d.ts", "next.config.ts", ".next/types/**/*.ts"],
  "exclude"         : ["dist", "build", "node_modules"]
}
