{
  "$schema"             : "https://turbo.build/schema.json",
  "globalDependencies"  : ["**/.env"],
  "tasks"               : {
    "build"       : {
      "dependsOn"   : ["^build"],
      "inputs"      : ["$TURBO_DEFAULT$", ".env*"],
      "outputs"     : ["!.next/cache/**", ".next/**", "dist/**"],
      "env"         : []
    },
    "lint"        : {
      "dependsOn"   : ["^lint"]
    },
    "check"       : {
      "dependsOn"   : ["^check"]
    },
    "dev"         : {
      "cache"       : false,
      "persistent"  : true
    },
    "clean"       : {
      "cache"       : false
    },
    "test"        : {
      "dependsOn"   : ["^build"]
    }
  }
}
